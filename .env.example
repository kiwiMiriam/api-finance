# =================================
# SERVER CONFIGURATION
# =================================
PORT=3000
NODE_ENV=development
DEV_MODE=true

# =================================
# SUPABASE CONFIGURATION
# =================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =================================
# FINANCIAL DATA API
# =================================
FINANCIAL_API_KEY=your-financial-modeling-prep-api-key
FINANCIAL_API_BASE_URL=https://financialmodelingprep.com/api/v3

# =================================
# RATE LIMITING CONFIGURATION
# =================================
PUBLIC_RATE_LIMIT_MAX=5
PUBLIC_RATE_LIMIT_WINDOW=3600000
AUTHENTICATED_RATE_LIMIT_MAX=100
AUTHENTICATED_RATE_LIMIT_WINDOW=3600000

# =================================
# CACHE CONFIGURATION
# =================================
CACHE_TTL_HOURS=24
ANALYSIS_CACHE_TTL=86400

# =================================
# SECURITY CONFIGURATION
# =================================
JWT_SECRET=your-jwt-secret-key
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# =================================
# SWAGGER DOCUMENTATION
# =================================
SWAGGER_ENABLED=true
SWAGGER_PATH=api/docs

# =================================
# AI EXPLANATION SERVICE (Optional)
# =================================
OPENAI_API_KEY=your-openai-api-key
AI_MODEL=gpt-3.5-turbo

# =================================
# LOGGING CONFIGURATION
# =================================
LOG_LEVEL=debug
LOG_FILE_ENABLED=false
LOG_FILE_PATH=./logs/app.log

# =================================
# MONITORING & HEALTH CHECK
# =================================
HEALTH_CHECK_ENABLED=true
METRICS_ENABLED=false

# =================================
# DEVELOPMENT SETTINGS
# =================================
# Set to true to use mock data when external APIs fail
FALLBACK_TO_MOCKS=true
# Set to true to always use mock data (for development)
FORCE_MOCK_DATA=false
